 \"Tilemap row cannot be empty\";\r\n            row.forEach((col, cindex) => {\r\n                if (rindex == 0 && cindex == 0) {\r\n                    this.mapWidth = col.width;\r\n                    this.mapHeight = col.height;\r\n                } else if (col.width != this.mapWidth || col.height != this.mapHeight) {\r\n                    throw \"All tilemaps must be of equal size\";\r\n                }\r\n            })\r\n        })\r\n        this.tilemapRows = tilemapRows;\r\n    }\r\n\r\n    getTile(x: number, y: number) {\r\n        let tileX = Math.floor(x / this.tileSize);\r\n        let tileY = Math.floor(y / this.tileSize);\r\n        let tilemapColIndex = Math.floor(tileX / this.mapWidth);\r\n        let tilemapRowIndex = Math.floor(tileY / this.mapHeight);\r\n        if (tilemapRowIndex >= this.tilemapRows.length) return this.emptyTile;\r\n\r\n        let tilemapRow = this.tilemapRows[tilemapRowIndex];\r\n        if (tilemapColIndex >= tilemapRow.length) return this.emptyTile;\r\n\r\n        let tilemapCol = tilemapRow[tilemapColIndex];\r\n        tileX = tileX % this.mapWidth;\r\n        tileY = tileY % this.mapHeight;\r\n        let tile = this.colormap[tilemapCol.getPixel(tileX, tileY)];\r\n        if (tile == null) return this.emptyTile;\r\n        return tile;\r\n    }\r\n}\r\n\r\nclass DTRenderer {\r\n    tilemap: DynamicTilemap;\r\n    mapWidth: number;\r\n    mapHeight: number;\r\n    xStart: number;\r\n    yStart: number;\r\n    xEnd: number;\r\n    yEnd: number;\r\n    offsetX: number;\r\n    offsetY: number;\r\n    renderable: Image;\r\n    sprite: Sprite;\r\n    screen: Sprite;\r\n\r\n    constructor(tilemap: DynamicTilemap, sprite: Sprite, offsetX: number = 0, offsetY: number = 0) {\r\n        this.tilemap = tilemap;\r\n        this.sprite = sprite;\r\n        this.offsetX = offsetX;\r\n        this.offsetY = offsetY;\r\n        this.renderable = image.create(scene.screenWidth(), scene.screenHeight());\r\n        this.screen = sprites.create(this.renderable);\r\n        this.screen.setFlag(SpriteFlag.RelativeToCamera, true);\r\n        this.screen.z = -1;\r\n        scene.cameraFollowSprite(this.sprite);\r\n\r\n        game.onUpdate(() => {\r\n            this.drawTilemap();\r\n        })\r\n    }\r\n\r\n    initialize() {\r\n        this.xStart = this.sprite.x - scene.screenWidth() / 2 + this.offsetX;\r\n        this.yStart = this.sprite.y - scene.screenHeight() / 2 + this.offsetY;\r\n        this.xEnd = this.xStart + scene.screenWidth();\r\n        this.yEnd = this.yStart + scene.screenHeight();\r\n    }\r\n\r\n    drawTilemap() {\r\n        let tile: Image;\r\n        if (this.tilemap.length == 0) return;\r\n\r\n        this.initialize();\r\n        for (let x = this.xStart; x < this.xEnd; x++) {\r\n            for (let y = this.yStart; y < this.yEnd; y++) {\r\n                if (x < 0 || y < 0) {\r\n                    this.renderable.setPixel(x - this.xStart, y - this.yStart, 0);\r\n                    continue;\r\n                }\r\n\r\n                tile = this.tilemap.getTile(x, y);\r\n                this.renderable.setPixel(\r\n                    x - this.xStart, y - this.yStart,\r\n                    tile.getPixel(Math.floor(x % this.tilemap.tileSize), Math.floor(y % this.tilemap.tileSize))\r\n                );\r\n            }\r\n        }\r\n        this.screen.setImage(this.renderable);\r\n    }\r\n}","README.md":" ","assets.json":"","tilemap.g.jres":"{\n    \"transparency16\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"tilemapTile\": true\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myTiles\"\n    }\n}","tilemap.g.ts":"","images.g.jres":"{\n    \"image2\": {\n       